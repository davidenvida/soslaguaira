# Backend SOS La Guaira - configuracion
# Copia este archivo a .env y ajusta los valores.

PORT=3000

# PostgreSQL
# Prod (Railway): definir DATABASE_URL (tiene prioridad sobre las DB_* de abajo).
#   DATABASE_URL=postgresql://user:pass@host:5432/dbname
# DB_SSL: true/false. Si no se define, se activa SSL automaticamente cuando hay DATABASE_URL.
#   En la red interna de Railway poner DB_SSL=false; via proxy publico, true.
# DATABASE_URL=
# DB_SSL=

# Dev local (fallback si no hay DATABASE_URL):
DB_HOST=localhost
DB_PORT=5432
DB_NAME=sosven
DB_USER=postgres
DB_PASS=tu_password_aqui

# CORS - origen del frontend (Vite)
CORS_ORIGIN=http://localhost:5173

# Uploads
MAX_UPLOAD_MB=5
